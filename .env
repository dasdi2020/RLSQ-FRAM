# RLSQ-FRAM Environment Configuration
# Ce fichier est versionné. Ne pas y mettre de secrets.
# Créez un .env.local pour les overrides locaux (gitignored).

APP_ENV=dev
APP_DEBUG=true
APP_SECRET=change_me_in_env_local

# Database
DATABASE_DRIVER=sqlite
DATABASE_PATH=var/db.sqlite

# Mailer
MAILER_DSN=null://null
MAILER_FROM=noreply@rlsq-fram.local

# JWT
JWT_SECRET=${APP_SECRET}
JWT_TTL=900
JWT_REFRESH_TTL=604800

# Server
APP_URL=http://localhost:8000
